---
interface Props {
  code: string;
  name: string;
  role: string;
  institution: string;
  education: string;
  orcid?: string;
  expertise: string[];
}

const { code, name, role, institution, education, orcid, expertise } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2);
---

<article class="team-member">
  <div class="member-photo">
    <span class="member-initials">{initials}</span>
  </div>
  <div class="member-info">
    <span class="specimen-code">{code}</span>
    <h3 class="member-name">{name}</h3>
    <p class="member-role">{role}</p>
    <p class="member-inst">{institution} · {education}</p>
    <div class="member-expertise">
      {expertise.map((e) => (
        <span class="tag">{e}</span>
      ))}
    </div>
    {orcid && (
      <a class="member-orcid" href={`https://orcid.org/${orcid}`} target="_blank" rel="noopener">
        ORCID {orcid}
      </a>
    )}
  </div>
</article>

<style>
  .team-member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .member-photo {
    width: 160px;
    height: 160px;
    border-radius: var(--r-full);
    border: 2px solid var(--accent-mid);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-alt);
    box-shadow: inset 0 2px 8px rgba(26, 23, 20, 0.06);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .team-member:hover .member-photo {
    transform: scale(1.02);
  }

  .member-initials {
    font-family: var(--f-display);
    font-size: var(--text-h1);
    color: var(--accent-mid);
    font-weight: 400;
    opacity: 0.6;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .member-name {
    font-family: var(--f-display);
    font-size: var(--text-h3);
    font-weight: 500;
    color: var(--txt-1);
    margin: 0;
  }

  .member-role {
    font-size: var(--text-body);
    color: var(--accent-mid);
    font-weight: 500;
    margin: 0;
  }

  .member-inst {
    font-size: var(--text-body-sm);
    color: var(--txt-3);
    margin: 0;
  }

  .member-expertise {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  .member-orcid {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    color: var(--txt-3);
    text-decoration: none;
    margin-top: var(--space-2);
  }

  .member-orcid:hover {
    color: var(--accent-mid);
  }
</style>
