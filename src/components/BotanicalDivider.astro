---
interface Props {
  variant: 1 | 2 | 3 | 4 | 5 | 6 | 7;
}

const { variant } = Astro.props;
---

<div class="botanical-divider" role="separator" aria-hidden="true">
  {variant === 1 && (
    <!-- Spore print — radial dots from center -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      {[...Array(24)].map((_, i) => {
        const angle = (i / 24) * Math.PI * 2;
        const r1 = 12;
        const r2 = 22;
        const cx1 = 200 + Math.cos(angle) * r1;
        const cy1 = 30 + Math.sin(angle) * r1;
        const cx2 = 200 + Math.cos(angle) * r2;
        const cy2 = 30 + Math.sin(angle) * r2;
        return (
          <>
            <circle cx={cx1} cy={cy1} r="1.2" fill="currentColor" />
            <circle cx={cx2} cy={cy2} r="0.8" fill="currentColor" opacity="0.6" />
          </>
        );
      })}
      <circle cx="200" cy="30" r="2" fill="currentColor" />
      {[...Array(12)].map((_, i) => {
        const angle = (i / 12) * Math.PI * 2 + 0.13;
        const cx = 200 + Math.cos(angle) * 28;
        const cy = 30 + Math.sin(angle) * 28;
        return <circle cx={cx} cy={cy} r="0.5" fill="currentColor" opacity="0.35" />;
      })}
    </svg>
  )}

  {variant === 2 && (
    <!-- Mycelium branching — organic branching lines -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M120 30 Q160 28 200 30 Q240 32 280 30" stroke="currentColor" stroke-width="0.8" />
      <path d="M155 30 Q165 18 180 12" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
      <path d="M175 30 Q180 38 195 44" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
      <path d="M210 30 Q220 20 235 16" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
      <path d="M230 30 Q238 40 250 46" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
      <path d="M180 12 Q188 8 196 10" stroke="currentColor" stroke-width="0.4" opacity="0.45" />
      <path d="M195 44 Q202 48 212 46" stroke="currentColor" stroke-width="0.4" opacity="0.45" />
      <path d="M235 16 Q242 10 252 12" stroke="currentColor" stroke-width="0.4" opacity="0.45" />
      <path d="M250 46 Q258 50 268 48" stroke="currentColor" stroke-width="0.4" opacity="0.45" />
      <circle cx="180" cy="12" r="1.5" fill="currentColor" opacity="0.5" />
      <circle cx="195" cy="44" r="1.5" fill="currentColor" opacity="0.5" />
      <circle cx="235" cy="16" r="1.5" fill="currentColor" opacity="0.5" />
      <circle cx="250" cy="46" r="1.5" fill="currentColor" opacity="0.5" />
    </svg>
  )}

  {variant === 3 && (
    <!-- Root cross-section — concentric rings -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="200" cy="30" r="4" stroke="currentColor" stroke-width="1" />
      <circle cx="200" cy="30" r="10" stroke="currentColor" stroke-width="0.6" opacity="0.7" />
      <circle cx="200" cy="30" r="17" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
      <circle cx="200" cy="30" r="24" stroke="currentColor" stroke-width="0.4" opacity="0.35" />
      <line x1="120" y1="30" x2="176" y2="30" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
      <line x1="224" y1="30" x2="280" y2="30" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
    </svg>
  )}

  {variant === 4 && (
    <!-- Hyphal network — connected nodes -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="160" cy="22" r="2.5" fill="currentColor" opacity="0.5" />
      <circle cx="190" cy="40" r="2" fill="currentColor" opacity="0.5" />
      <circle cx="220" cy="18" r="2.5" fill="currentColor" opacity="0.5" />
      <circle cx="240" cy="42" r="2" fill="currentColor" opacity="0.5" />
      <circle cx="200" cy="30" r="3" fill="currentColor" opacity="0.65" />
      <line x1="160" y1="22" x2="200" y2="30" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
      <line x1="190" y1="40" x2="200" y2="30" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
      <line x1="220" y1="18" x2="200" y2="30" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
      <line x1="240" y1="42" x2="200" y2="30" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
      <line x1="160" y1="22" x2="190" y2="40" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
      <line x1="220" y1="18" x2="240" y2="42" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
      <circle cx="140" cy="32" r="1.5" fill="currentColor" opacity="0.3" />
      <circle cx="260" cy="26" r="1.5" fill="currentColor" opacity="0.3" />
      <line x1="140" y1="32" x2="160" y2="22" stroke="currentColor" stroke-width="0.3" opacity="0.2" />
      <line x1="260" y1="26" x2="240" y2="42" stroke="currentColor" stroke-width="0.3" opacity="0.2" />
    </svg>
  )}

  {variant === 5 && (
    <!-- Spore dispersal — wind-blown dots -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="170" cy="30" r="2.5" fill="currentColor" opacity="0.7" />
      <circle cx="185" cy="26" r="1.8" fill="currentColor" opacity="0.55" />
      <circle cx="202" cy="32" r="1.3" fill="currentColor" opacity="0.45" />
      <circle cx="218" cy="24" r="1" fill="currentColor" opacity="0.35" />
      <circle cx="232" cy="34" r="0.8" fill="currentColor" opacity="0.28" />
      <circle cx="248" cy="28" r="0.6" fill="currentColor" opacity="0.2" />
      <circle cx="262" cy="36" r="0.5" fill="currentColor" opacity="0.15" />
      <path d="M160 30 Q190 22 230 28 Q260 32 280 26" stroke="currentColor" stroke-width="0.3" opacity="0.2" stroke-dasharray="2 4" />
      <circle cx="195" cy="42" r="0.7" fill="currentColor" opacity="0.3" />
      <circle cx="215" cy="16" r="0.6" fill="currentColor" opacity="0.25" />
      <circle cx="240" cy="44" r="0.5" fill="currentColor" opacity="0.18" />
    </svg>
  )}

  {variant === 6 && (
    <!-- Substrate layers — wavy horizontal strata -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M130 18 Q165 14 200 18 Q235 22 270 18" stroke="currentColor" stroke-width="0.6" opacity="0.35" />
      <path d="M120 28 Q160 24 200 28 Q240 32 280 28" stroke="currentColor" stroke-width="0.8" opacity="0.55" />
      <path d="M125 38 Q162 42 200 38 Q238 34 275 38" stroke="currentColor" stroke-width="0.6" opacity="0.45" />
      <path d="M135 48 Q167 44 200 48 Q233 52 265 48" stroke="currentColor" stroke-width="0.4" opacity="0.3" />
      <circle cx="200" cy="28" r="1" fill="currentColor" opacity="0.4" />
      <circle cx="180" cy="38" r="0.6" fill="currentColor" opacity="0.3" />
      <circle cx="222" cy="18" r="0.6" fill="currentColor" opacity="0.25" />
    </svg>
  )}

  {variant === 7 && (
    <!-- Root system — downward branching -->
    <svg viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 6 L200 30" stroke="currentColor" stroke-width="0.9" />
      <path d="M200 20 Q185 28 175 40" stroke="currentColor" stroke-width="0.7" opacity="0.7" />
      <path d="M200 20 Q215 28 225 40" stroke="currentColor" stroke-width="0.7" opacity="0.7" />
      <path d="M200 30 Q190 38 182 50" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
      <path d="M200 30 Q210 38 218 50" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
      <path d="M175 40 Q168 46 162 54" stroke="currentColor" stroke-width="0.4" opacity="0.35" />
      <path d="M225 40 Q232 46 238 54" stroke="currentColor" stroke-width="0.4" opacity="0.35" />
      <path d="M175 40 Q172 48 174 56" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
      <path d="M225 40 Q228 48 226 56" stroke="currentColor" stroke-width="0.3" opacity="0.25" />
      <circle cx="200" cy="6" r="2" fill="currentColor" opacity="0.5" />
    </svg>
  )}
</div>
