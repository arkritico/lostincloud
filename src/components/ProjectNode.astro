---
interface Props {
  code: string;
  name: string;
  title: string;
  description: string;
  status: 'active' | 'completed';
  statusLabel: string;
  timeline: string;
  budget?: string;
  euIncentive?: string;
  partners: string[];
  featured?: boolean;
  partnersLabel: string;
  budgetLabel: string;
  timelineLabel: string;
}

const { code, name, title, description, status, statusLabel, timeline, budget, euIncentive, partners, featured, partnersLabel, budgetLabel, timelineLabel } = Astro.props;
---

<article class={`project-node ${featured ? 'project-node--featured' : ''}`}>
  <div class="project-dot">
    <span class={`dot ${status}`}></span>
  </div>
  <div class="project-content card">
    <div class="project-header">
      <span class="specimen-code">{code}</span>
      <span class={`project-status ${status}`}>{statusLabel}</span>
    </div>
    <h3 class="project-name">{name}</h3>
    <p class="project-title">{title}</p>
    <p class="project-desc">{description}</p>
    <div class="project-meta">
      <div class="meta-item">
        <span class="meta-label">{timelineLabel}</span>
        <span class="meta-value">{timeline}</span>
      </div>
      {budget && (
        <div class="meta-item">
          <span class="meta-label">{budgetLabel}</span>
          <span class="meta-value">{budget}{euIncentive ? ` (EU: ${euIncentive})` : ''}</span>
        </div>
      )}
      {partners.length > 0 && (
        <div class="meta-item">
          <span class="meta-label">{partnersLabel}</span>
          <span class="meta-value">{partners.join(', ')}</span>
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .project-node {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-4);
    position: relative;
  }

  .project-dot {
    display: flex;
    justify-content: center;
    padding-top: var(--space-8);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: var(--r-full);
    flex-shrink: 0;
    position: relative;
    z-index: var(--z-card);
  }

  .dot.active {
    background: var(--accent-mid);
    box-shadow: 0 0 0 4px var(--accent-light);
  }

  .dot.completed {
    background: var(--hairline);
    border: 2px solid var(--txt-3);
  }

  .project-content {
    padding: var(--space-6);
  }

  .project-node--featured .project-content {
    border-color: var(--accent-mid);
    border-width: 2px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .project-status {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--r-full);
  }

  .project-status.active {
    background: var(--accent-light);
    color: var(--accent);
  }

  .project-status.completed {
    background: var(--bg-alt);
    color: var(--txt-3);
  }

  .project-name {
    font-family: var(--f-display);
    font-size: var(--text-h2);
    font-weight: 500;
    color: var(--accent);
    margin: 0;
  }

  .project-title {
    font-size: var(--text-body);
    color: var(--txt-2);
    font-style: italic;
    margin: var(--space-1) 0 var(--space-3);
  }

  .project-desc {
    font-size: var(--text-body);
    color: var(--txt-2);
    line-height: 1.65;
    margin: 0 0 var(--space-4);
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--hairline);
  }

  .meta-item {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-body-sm);
  }

  .meta-label {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    color: var(--txt-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-width: 80px;
    flex-shrink: 0;
  }

  .meta-value {
    color: var(--txt-2);
  }
</style>
