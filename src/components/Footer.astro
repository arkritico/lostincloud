---
interface Props {
  locale: 'pt' | 'en';
}

const { locale } = Astro.props;
const year = new Date().getFullYear();

const t = locale === 'pt'
  ? {
      tagline: 'Laboratorio de investigacao em micologia',
      privacy: 'Politica de Privacidade',
      visit: 'Visitar rhizologic.com',
      eu: 'Barra de cofinanciamento UE',
    }
  : {
      tagline: 'Mycology research laboratory',
      privacy: 'Privacy Policy',
      visit: 'Visit rhizologic.com',
      eu: 'EU co-finance bar',
    };
---

<footer class="footer">
  <div class="footer__hairline"></div>
  <div class="footer__inner">
    <div class="footer__left">
      <p class="footer__company">Lost in Cloud, Lda</p>
      <p class="footer__tagline">{t.tagline}</p>
      <p class="footer__copy">&copy; {year} Lost in Cloud, Lda</p>
    </div>
    <div class="footer__right">
      <a href={locale === 'pt' ? '/privacidade' : '/en/privacy'} class="footer__link">
        {t.privacy}
      </a>
      <a href="https://rhizologic.com" class="footer__link" rel="noopener" target="_blank">
        {t.visit}
      </a>
    </div>
  </div>

  <!-- EU co-finance bar placeholder — replace with <EuCofinanceBar /> component -->
  <div class="footer__eu" aria-label={t.eu}></div>
</footer>

<style>
  .footer {
    background: var(--bg-alt);
  }

  .footer__hairline {
    height: 1px;
    background: var(--hairline);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: var(--grid-max);
    margin-inline: auto;
    padding: var(--space-12) var(--grid-margin) var(--space-8);
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer__company {
    font-family: var(--f-display);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--txt-1);
    margin-bottom: var(--space-1);
  }

  .footer__tagline {
    font-size: var(--text-body-sm);
    color: var(--txt-3);
    margin-bottom: var(--space-4);
  }

  .footer__copy {
    font-size: var(--text-micro);
    color: var(--txt-3);
  }

  .footer__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .footer__right {
      text-align: right;
    }
  }

  .footer__link {
    font-size: var(--text-body-sm);
    color: var(--txt-2);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__link:hover {
    color: var(--accent);
  }

  .footer__eu {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding: var(--space-6) var(--grid-margin) var(--space-8);
  }
</style>
