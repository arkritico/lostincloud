---
interface Props {
  locale: 'pt' | 'en';
}

const { locale } = Astro.props;
const year = new Date().getFullYear();

const labels = locale === 'pt'
  ? {
      privacy: 'Política de Privacidade',
      euAlt: 'Compete 2030 / Lisboa 2030 — cofinanciamento europeu',
    }
  : {
      privacy: 'Privacy Policy',
      euAlt: 'Compete 2030 / Lisboa 2030 — European co-financing',
    };
---

<footer class="footer">
  <div class="footer__top"></div>

  <div class="footer__inner">
    <p class="footer__copy">
      &copy; {year} Lost in Cloud, Lda
    </p>
    <a
      href={locale === 'pt' ? '/privacidade' : '/en/privacy'}
      class="footer__link"
    >
      {labels.privacy}
    </a>
  </div>

  <!-- EU co-finance bar — mandatory white background -->
  <div class="footer__eu">
    <img
      src="/images/eu/C2030_Lisboa2030.png"
      alt={labels.euAlt}
      class="footer__eu-img"
      loading="lazy"
      decoding="async"
    />
  </div>
</footer>

<style>
  .footer {
    background: var(--bench-dark);
  }

  .footer__top {
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    max-width: var(--bench-max);
    margin-inline: auto;
    padding: var(--space-8) var(--bench-margin);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copy {
    font-family: var(--f-body);
    font-size: var(--text-body-sm);
    color: var(--cream);
    margin: 0;
  }

  .footer__link {
    font-family: var(--f-body);
    font-size: var(--text-body-sm);
    color: var(--cream);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .footer__link:hover {
    opacity: 1;
    color: var(--cream);
  }

  /* ── EU co-finance bar — mandatory white background ── */
  .footer__eu {
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--bench-margin);
  }

  .footer__eu-img {
    max-width: 100%;
    max-height: 64px;
    object-fit: contain;
  }
</style>
