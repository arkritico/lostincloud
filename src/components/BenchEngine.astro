---
// BenchEngine — Astro island for Lenis smooth scroll + GSAP ScrollTrigger + spotlight cursor
// Loaded as client:load on the main bench page
---

<div class="spotlight" id="spotlight"></div>

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // === LENIS SMOOTH SCROLL (desktop only) ===
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let lenis: Lenis | null = null;

  if (!isMobile && !prefersReducedMotion) {
    lenis = new Lenis({
      duration: 1.4,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 0, // Don't interfere with native touch scroll
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time: number) => {
      lenis!.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);
  }

  // === SCROLL-DRIVEN REVEALS ===
  if (!prefersReducedMotion) {
    // Reveal bench objects as they enter viewport
    const revealElements = document.querySelectorAll('[data-bench-reveal]');

    revealElements.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      const delay = parseFloat(htmlEl.dataset.benchDelay || '0');

      gsap.fromTo(
        el,
        {
          opacity: 0,
          y: 60,
        },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          delay,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    // Parallax: background panels scroll slower than content
    const parallaxPanels = document.querySelectorAll('[data-bench-parallax]');
    parallaxPanels.forEach((panel) => {
      const speed = parseFloat((panel as HTMLElement).dataset.benchParallax || '0.15');
      gsap.to(panel, {
        yPercent: speed * 100,
        ease: 'none',
        scrollTrigger: {
          trigger: panel,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        },
      });
    });
  }

  // === SPOTLIGHT CURSOR (desktop only, hover devices) ===
  const spotlight = document.getElementById('spotlight');

  if (spotlight && !isMobile && !prefersReducedMotion) {
    let mouseX = 0;
    let mouseY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    gsap.ticker.add(() => {
      gsap.set(spotlight, {
        x: mouseX - 200,
        y: mouseY - 200,
      });
    });
  }

  // === ASTRO PAGE LIFECYCLE CLEANUP ===
  document.addEventListener('astro:before-swap', () => {
    gsap.globalTimeline.clear();
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }
  });
</script>
