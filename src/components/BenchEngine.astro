---
// BenchEngine — Lenis smooth scroll + GSAP ScrollTrigger flyover + spotlight cursor
// Each .bench-zone has a tall background image that scrolls (object-position scrub)
// creating the illusion of flying over the bench
---

<div class="spotlight" id="spotlight"></div>

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // === LENIS SMOOTH SCROLL (desktop only) ===
  let lenis: Lenis | null = null;

  if (!isMobile && !prefersReducedMotion) {
    lenis = new Lenis({
      duration: 1.6,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 0,
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time: number) => {
      lenis!.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);
  }

  // === FLYOVER: Background image scroll ===
  if (!prefersReducedMotion) {
    // Each .bench-bg-tall scrolls its object-position as the zone scrolls through viewport
    const zones = document.querySelectorAll('.bench-zone');

    zones.forEach((zone) => {
      const bg = zone.querySelector('.bench-bg-tall') as HTMLElement;
      if (!bg) return;

      // Scrub the background image from top to bottom
      gsap.fromTo(
        bg,
        { objectPosition: '50% 0%' },
        {
          objectPosition: '50% 100%',
          ease: 'none',
          scrollTrigger: {
            trigger: zone,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.8,
          },
        }
      );

      // Subtle zoom pulse as zone passes through center
      gsap.fromTo(
        bg,
        { scale: 1.0 },
        {
          scale: 1.04,
          ease: 'none',
          scrollTrigger: {
            trigger: zone,
            start: 'top bottom',
            end: 'center center',
            scrub: 0.8,
          },
        }
      );
      gsap.fromTo(
        bg,
        { scale: 1.04 },
        {
          scale: 1.0,
          ease: 'none',
          scrollTrigger: {
            trigger: zone,
            start: 'center center',
            end: 'bottom top',
            scrub: 0.8,
          },
        }
      );
    });

    // === CONTENT REVEALS ===
    const revealElements = document.querySelectorAll('[data-bench-reveal]');

    revealElements.forEach((el) => {
      const htmlEl = el as HTMLElement;
      const delay = parseFloat(htmlEl.dataset.benchDelay || '0');

      gsap.fromTo(
        el,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          delay,
          ease: 'back.out(1.2)',
          scrollTrigger: {
            trigger: el,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        }
      );
    });
  } else {
    // Reduced motion: show everything, no animation
    document.querySelectorAll('[data-bench-reveal]').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  }

  // === SPOTLIGHT CURSOR (desktop, hover devices) ===
  const spotlight = document.getElementById('spotlight');

  if (spotlight && !isMobile && !prefersReducedMotion) {
    document.addEventListener('mousemove', (e) => {
      gsap.to(spotlight, {
        x: e.clientX - 200,
        y: e.clientY - 200,
        duration: 0.4,
        ease: 'power2.out',
        overwrite: 'auto',
      });
    });
  }

  // === CLEANUP ===
  document.addEventListener('astro:before-swap', () => {
    gsap.globalTimeline.clear();
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }
  });
</script>
