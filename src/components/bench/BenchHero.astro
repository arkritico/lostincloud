---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const subtitle = t(locale, 'hero.subtitle');
const credentials = t(locale, 'hero.credentials');
const scrollLabel = t(locale, 'hero.scroll');
---

<section class="bench-zone bench-hero" id="hero">
  <img
    class="bench-bg"
    src="/images/bench/sequence/01-hero.webp"
    alt=""
    aria-hidden="true"
    width="1400"
    height="764"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="bench-hero-overlay"></div>
  <div class="bench-hero-content" data-bench-reveal>
    <h1 class="bench-hero-title">lostincloud</h1>
    <p class="bench-hero-subtitle">{subtitle}</p>
    <p class="bench-hero-credentials">{credentials}</p>
  </div>
  <a href="#sobre" class="scroll-indicator" aria-label={scrollLabel}>
    <span class="scroll-indicator-arrow">↓</span>
  </a>
</section>

<style>
  .bench-hero {
    min-height: 100vh;
    min-height: 100dvh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .bench-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: var(--z-bench);
  }

  /* Semi-transparent overlay for text legibility on the right side */
  .bench-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 30%,
      rgba(245, 240, 225, 0.55) 55%,
      rgba(245, 240, 225, 0.75) 70%,
      rgba(245, 240, 225, 0.85) 100%
    );
    z-index: var(--z-flat);
    pointer-events: none;
  }

  .bench-hero-content {
    position: relative;
    z-index: var(--z-raised);
    width: 40%;
    max-width: 520px;
    padding-right: var(--bench-margin);
    padding-left: var(--space-8);
  }

  .bench-hero-title {
    font-family: var(--f-display);
    font-size: var(--text-display);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
    text-shadow: 0 1px 2px rgba(245, 240, 225, 0.6);
  }

  .bench-hero-subtitle {
    font-family: var(--f-mono);
    font-size: var(--text-label);
    color: var(--pencil);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1.5;
    margin-bottom: var(--space-3);
    max-width: 40ch;
  }

  .bench-hero-credentials {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    color: var(--faded);
    letter-spacing: 0.05em;
    line-height: 1.6;
    max-width: 45ch;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-raised);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--pencil);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
  }

  .scroll-indicator:hover {
    color: var(--ink);
    transform: translateX(-50%) translateY(4px);
  }

  .scroll-indicator-arrow {
    font-size: 1.5rem;
    line-height: 1;
    animation: bounce-arrow 2s var(--ease-out) infinite;
  }

  @keyframes bounce-arrow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .bench-hero {
      justify-content: center;
      align-items: flex-end;
      padding-bottom: var(--space-20);
    }

    .bench-hero-overlay {
      background: linear-gradient(
        to top,
        rgba(245, 240, 225, 0.9) 0%,
        rgba(245, 240, 225, 0.7) 40%,
        rgba(245, 240, 225, 0.3) 70%,
        transparent 100%
      );
    }

    .bench-hero-content {
      width: 100%;
      max-width: 100%;
      padding: 0 var(--bench-margin);
      text-align: center;
    }

    .bench-hero-subtitle,
    .bench-hero-credentials {
      max-width: 100%;
    }

    .scroll-indicator {
      bottom: var(--space-4);
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator-arrow {
      animation: none;
    }
  }
</style>
