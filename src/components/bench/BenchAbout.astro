---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const kicker = t(locale, 'sections.sobre.kicker');
const title = t(locale, 'sections.sobre.title');

const aboutText: Record<string, string> = {
  pt: 'A Lost in Cloud (anteriormente Soilvitae) é uma empresa portuguesa de biotecnologia especializada em soluções agrícolas sustentáveis. Fundada em 2014, opera a partir do Tec Labs — o centro de inovação da Faculdade de Ciências da Universidade de Lisboa — onde desenvolve investigação aplicada em micologia, saúde do solo e biocontrolo.',
  en: 'Lost in Cloud (formerly Soilvitae) is a Portuguese biotechnology company specializing in sustainable agricultural solutions. Founded in 2014, it operates from Tec Labs — the innovation hub of the Faculty of Sciences at the University of Lisbon — where it conducts applied research in mycology, soil health, and biocontrol.',
};

const facts: { label: Record<string, string>; value: string }[] = [
  { label: { pt: 'Fundada', en: 'Founded' }, value: '2014' },
  { label: { pt: 'Lab', en: 'Lab' }, value: 'Tec Labs, ULisboa' },
  { label: { pt: 'Entidade', en: 'Entity' }, value: 'Lost in Cloud, Lda' },
  { label: { pt: 'Equipa', en: 'Team' }, value: locale === 'pt' ? '5 investigadores' : '5 researchers' },
  { label: { pt: 'Projetos I&D', en: 'R&D Projects' }, value: '8' },
];
---

<section class="bench-zone bench-about" id="sobre">
  <img
    class="bench-bg-tall"
    src="/images/bench/sequence/02-about.webp"
    alt=""
    aria-hidden="true"
    width="1400"
    height="764"
    loading="lazy"
    decoding="async"
  />
  <div class="bench-about-overlay"></div>
  <div class="bench-about-layout">
    <div class="bench-about-content" data-bench-reveal>
      <p class="kicker">{kicker}</p>
      <h2 class="bench-about-title">{title}</h2>
      <p class="bench-about-text">{aboutText[locale]}</p>
    </div>
    <aside class="bench-about-facts" data-bench-reveal data-bench-delay="0.2">
      <div class="bench-about-facts-inner">
        {facts.map((fact) => (
          <dl class="bench-fact">
            <dt class="bench-fact-label">{fact.label[locale]}</dt>
            <dd class="bench-fact-value">{fact.value}</dd>
          </dl>
        ))}
      </div>
    </aside>
  </div>
</section>

<style>
  .bench-about {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-16);
    overflow: hidden;
  }


  .bench-about-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(245, 240, 225, 0.85) 0%,
      rgba(245, 240, 225, 0.7) 50%,
      rgba(245, 240, 225, 0.45) 75%,
      transparent 100%
    );
    z-index: var(--z-flat);
    pointer-events: none;
  }

  .bench-about-layout {
    position: relative;
    z-index: var(--z-raised);
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: var(--space-12);
    max-width: var(--bench-max);
    width: 100%;
    padding-inline: var(--bench-margin);
    align-items: start;
  }

  /* ── Main content (notebook pages area) ── */
  .bench-about-content {
    max-width: 60ch;
  }

  .bench-about-title {
    font-family: var(--f-display);
    font-size: var(--text-h1);
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-6);
    line-height: 1.15;
    text-shadow: 0 1px 2px rgba(245, 240, 225, 0.5);
  }

  .bench-about-text {
    font-family: var(--f-body);
    font-size: var(--text-body-lg);
    color: var(--pencil);
    line-height: 1.75;
    max-width: 55ch;
    text-shadow: 0 0 8px rgba(245, 240, 225, 0.8);
  }

  /* ── Facts sidebar (margin annotations) ── */
  .bench-about-facts {
    padding-top: var(--space-10);
  }

  .bench-about-facts-inner {
    background: rgba(245, 240, 225, 0.6);
    backdrop-filter: blur(4px);
    padding: var(--space-5) var(--space-4);
    border-left: 2px solid var(--bench-dark);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bench-fact {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bench-fact-label {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    color: var(--faded);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .bench-fact-value {
    font-family: var(--f-mono);
    font-size: var(--text-body-sm);
    color: var(--ink);
    letter-spacing: 0.02em;
    margin: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .bench-about {
      min-height: auto;
      padding-block: var(--space-12);
    }

    .bench-about-overlay {
      background: rgba(245, 240, 225, 0.85);
    }

    .bench-about-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .bench-about-content {
      max-width: 100%;
    }

    .bench-about-text {
      max-width: 100%;
    }

    .bench-about-facts-inner {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-4) var(--space-6);
      border-left: none;
      border-top: 2px solid var(--bench-dark);
      padding: var(--space-4) 0 0;
      background: transparent;
      backdrop-filter: none;
    }
  }
</style>
