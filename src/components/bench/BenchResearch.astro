---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';
import { projects } from '../../data/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const rotations = [-2.5, 1.8, -0.7, 2.1, -1.5, 0.9, -2.0, 1.3];
const stampRotations = [-6, -3, -8, -4, -5, -7, -3, -6];
---

<section id="investigacao" class="bench-zone research-zone">
  <img
    src="/images/bench/sequence/05-research.webp"
    alt=""
    class="bench-bg"
    loading="lazy"
    decoding="async"
  />

  <div class="research-content bench">
    <p class="kicker">{t(locale, 'sections.investigacao.kicker')}</p>
    <h2 data-bench-reveal>{t(locale, 'sections.investigacao.title')}</h2>

    <div class="research-grid">
      {projects.map((project, i) => (
        <div
          class:list={['paper', 'fiche', { 'fiche--featured': project.featured }]}
          style={`--rotate: ${rotations[i % rotations.length]}deg`}
          data-bench-reveal
          data-delay={i * 120}
        >
          <div class="paper-clip" aria-hidden="true"></div>

          <span class="specimen-code">{project.code}</span>
          <h3 class="fiche-name">{project.name}</h3>
          <p class="fiche-title">{project.title[locale]}</p>

          <div class="fiche-meta">
            <span class="fiche-meta-item">
              <span class="fiche-meta-label">{t(locale, 'common.timeline')}</span>
              {project.timeline}
            </span>
            {project.budget && (
              <span class="fiche-meta-item">
                <span class="fiche-meta-label">{t(locale, 'common.budget')}</span>
                {project.budget}
              </span>
            )}
          </div>

          {project.partners.length > 0 && (
            <div class="fiche-partners">
              <span class="fiche-meta-label">{t(locale, 'common.partners')}</span>
              <span class="fiche-partners-list">{project.partners.join(' \u00b7 ')}</span>
            </div>
          )}

          {project.status === 'active' ? (
            <span
              class="stamp stamp--active"
              style={`--stamp-rotate: ${stampRotations[i % stampRotations.length]}deg`}
            >
              {t(locale, 'common.active')}
            </span>
          ) : (
            <span
              class="stamp stamp--completed"
              style={`--stamp-rotate: ${stampRotations[i % stampRotations.length]}deg`}
            >
              {t(locale, 'common.completed')}
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .research-zone {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .bench-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: var(--z-bench);
  }

  .research-content {
    position: relative;
    z-index: var(--z-raised);
    width: 100%;
    padding-block: var(--space-16);
  }

  .research-content h2 {
    font-family: var(--f-display);
    font-size: var(--text-h1);
    margin-bottom: var(--space-10);
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .fiche {
    position: relative;
    backdrop-filter: blur(6px);
    background: rgba(245, 240, 225, 0.92);
  }

  .fiche--featured {
    grid-column: span 2;
    grid-row: span 1;
    padding: var(--space-8);
  }

  .fiche--featured .fiche-name {
    font-size: var(--text-h2);
  }

  .fiche-name {
    font-family: var(--f-display);
    font-size: var(--text-h3);
    font-weight: 700;
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
    color: var(--ink);
  }

  .fiche-title {
    font-family: var(--f-body);
    color: var(--pencil);
    font-size: var(--text-body-sm);
    line-height: 1.5;
    margin-bottom: var(--space-4);
  }

  .fiche-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .fiche-meta-item {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    color: var(--faded);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .fiche-meta-label {
    font-family: var(--f-mono);
    font-size: var(--text-micro);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--faded);
  }

  .fiche-partners {
    margin-bottom: var(--space-4);
  }

  .fiche-partners-list {
    font-family: var(--f-body);
    font-size: var(--text-body-sm);
    color: var(--pencil);
    display: block;
    margin-top: var(--space-1);
  }

  .stamp {
    margin-top: var(--space-3);
  }

  /* Overlapping effect via negative margins on alternating cards */
  .fiche:nth-child(even) {
    margin-top: var(--space-6);
  }

  .fiche:nth-child(3n + 1) {
    margin-top: calc(-1 * var(--space-3));
  }

  @media (max-width: 768px) {
    .research-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .fiche--featured {
      grid-column: span 1;
    }

    .fiche:nth-child(even),
    .fiche:nth-child(3n + 1) {
      margin-top: 0;
    }
  }
</style>
