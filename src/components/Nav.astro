---
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  locale: 'pt' | 'en';
}

const { locale } = Astro.props;
const currentPath = locale === 'pt' ? '/' : '/en/';

const labels: Record<string, Record<string, string>> = {
  pt: {
    sobre: 'Sobre',
    servicos: 'Servicos',
    produtos: 'Produtos',
    investigacao: 'Investigacao',
    equipa: 'Equipa',
    contacto: 'Contacto',
    menu: 'Menu',
    close: 'Fechar',
  },
  en: {
    sobre: 'About',
    servicos: 'Services',
    produtos: 'Products',
    investigacao: 'Research',
    equipa: 'Team',
    contacto: 'Contact',
    menu: 'Menu',
    close: 'Close',
  },
};

const t = labels[locale];
const anchors = ['sobre', 'servicos', 'produtos', 'investigacao', 'equipa', 'contacto'];
---

<nav class="nav" aria-label={locale === 'pt' ? 'Navegacao principal' : 'Main navigation'}>
  <!-- Checkbox lives at nav root so ~ selectors reach overlay -->
  <input
    type="checkbox"
    id="nav-toggle"
    class="nav__checkbox sr-only"
    aria-label={t.menu}
  />

  <div class="nav__inner">
    <!-- Logo -->
    <a href={currentPath} class="nav__logo" aria-label="lostincloud — home">
      lostincloud
    </a>

    <!-- Desktop links -->
    <ul class="nav__links" role="list">
      {anchors.map((id) => (
        <li>
          <a href={`#${id}`} class="nav__link">{t[id]}</a>
        </li>
      ))}
    </ul>

    <!-- Language toggle + hamburger -->
    <div class="nav__right">
      <LanguageToggle locale={locale} currentPath={currentPath} />

      <label for="nav-toggle" class="nav__hamburger" aria-hidden="true">
        <span class="nav__hamburger-bar"></span>
        <span class="nav__hamburger-bar"></span>
        <span class="nav__hamburger-bar"></span>
      </label>
    </div>
  </div>

  <!-- Mobile overlay -->
  <div class="nav__overlay" aria-hidden="true">
    <ul class="nav__overlay-links" role="list">
      {anchors.map((id) => (
        <li>
          <a href={`#${id}`} class="nav__overlay-link">{t[id]}</a>
        </li>
      ))}
    </ul>
    <div class="nav__overlay-lang">
      <LanguageToggle locale={locale} currentPath={currentPath} />
    </div>
  </div>
</nav>

<style>
  /* ── Nav bar ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-normal) var(--ease-out);
  }

  /* Show hairline on scroll — triggered by page having scrolled */
  @supports (animation-timeline: scroll()) {
    .nav {
      animation: nav-border linear both;
      animation-timeline: scroll();
      animation-range: 0px 80px;
    }

    @keyframes nav-border {
      to {
        border-bottom-color: var(--hairline);
      }
    }
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    height: 3.5rem;
  }

  /* ── Logo ── */
  .nav__logo {
    font-family: var(--f-display);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--txt-1);
    text-decoration: none;
    text-transform: lowercase;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav__logo:hover {
    color: var(--accent);
  }

  /* ── Desktop links ── */
  .nav__links {
    display: none;
    list-style: none;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav__links {
      display: flex;
    }
  }

  .nav__link {
    position: relative;
    font-family: var(--f-body);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--txt-2);
    text-decoration: none;
    padding-block: var(--space-2);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav__link:hover {
    color: var(--accent);
  }

  /* Underline-from-center on hover */
  .nav__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .nav__link:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* ── Right section ── */
  .nav__right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Hamburger ── */
  .nav__checkbox {
    display: none;
  }

  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .nav__hamburger {
      display: none;
    }
  }

  .nav__hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--txt-1);
    border-radius: 1px;
    transition:
      transform var(--duration-normal) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }

  /* Hamburger -> X transform (checkbox is sibling of .nav__inner) */
  .nav__checkbox:checked ~ .nav__inner .nav__hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav__checkbox:checked ~ .nav__inner .nav__hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .nav__checkbox:checked ~ .nav__inner .nav__hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  .nav__overlay {
    position: fixed;
    inset: 0;
    top: 3.5rem;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-10);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--duration-normal) var(--ease-out),
      visibility var(--duration-normal);
    z-index: calc(var(--z-nav) - 1);
  }

  .nav__checkbox:checked ~ .nav__overlay {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 768px) {
    .nav__overlay {
      display: none;
    }
  }

  .nav__overlay-links {
    list-style: none;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .nav__overlay-link {
    font-family: var(--f-display);
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--txt-1);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav__overlay-link:hover {
    color: var(--accent);
  }

  .nav__overlay-lang {
    margin-top: var(--space-4);
  }
</style>
