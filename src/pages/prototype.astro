---
// Flyover prototype — hero scene only, 4 key frames
---

<!doctype html>
<html lang="pt">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#D4C5A0" />
  <title>A Bancada — Flyover Prototype</title>
  <link rel="preload" href="/images/bench/sequence/01-hero.webp" as="image" />
  <link rel="preload" href="/images/bench/sequence/hero-key-2.webp" as="image" />
  <link rel="preload" href="/images/bench/sequence/hero-key-3.webp" as="image" />
  <link rel="preload" href="/images/bench/sequence/hero-key-4.webp" as="image" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #D4C5A0;
      font-family: 'Newsreader', Georgia, serif;
      color: #3A3228;
    }

    .flyover {
      height: 400vh;
      position: relative;
    }

    .flyover-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 100%;
      overflow: hidden;
    }

    .flyover-layer {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    .flyover-frame {
      position: absolute;
      top: -10%;
      left: 0;
      width: 100%;
      height: 120%;
      object-fit: cover;
      will-change: transform;
    }

    .flyover-layer--back { z-index: 0; }
    .flyover-layer--front { z-index: 1; }

    .flyover-layer { transition: opacity 0.3s ease-out; }
    .flyover-layer.is-hidden { opacity: 0; }

    /* Content overlay */
    .flyover-content {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      pointer-events: none;
    }

    .flyover-scrim {
      background: rgba(212, 197, 160, 0.6);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      padding: 2.5rem 3rem;
      border-radius: 2px;
    }

    .flyover-content h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    .flyover-content p {
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(0.65rem, 1.2vw, 0.8rem);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #6B6358;
    }

    /* Scroll indicator */
    .scroll-hint {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: #9B9488;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      animation: pulse 2s ease-in-out infinite;
    }

    .scroll-hint span {
      display: block;
      text-align: center;
      margin-top: 0.5rem;
      font-size: 1.2rem;
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }

    /* Frame counter (debug) */
    .frame-counter {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 30;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: #9B9488;
      background: rgba(212, 197, 160, 0.8);
      padding: 0.3rem 0.6rem;
      border-radius: 2px;
    }
  </style>
</head>
<body>
  <div class="flyover" id="flyover">
    <div class="flyover-sticky">
      <!-- Two layers: one pans, the other preloads next frame underneath -->
      <div class="flyover-layer flyover-layer--back" id="layer-back">
        <img class="flyover-frame" src="/images/bench/sequence/01-hero.webp" alt="" />
      </div>
      <div class="flyover-layer flyover-layer--front" id="layer-front">
        <img class="flyover-frame" src="/images/bench/sequence/01-hero.webp" alt="" />
      </div>

      <div class="flyover-content">
        <div class="flyover-scrim">
          <h1>lostincloud</h1>
          <p>Laboratório de Investigação em Micologia</p>
          <p style="margin-top: 0.5rem; font-size: 0.65rem; color: #9B9488;">
            Est. 2014 · Tec Labs, Universidade de Lisboa · 8 Projetos I&D
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-hint" id="scroll-hint">
    scroll
    <span>↓</span>
  </div>

  <div class="frame-counter" id="counter">F1/4</div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    document.addEventListener('DOMContentLoaded', () => {
      gsap.registerPlugin(ScrollTrigger);

      const frames = [
        '/images/bench/sequence/01-hero.webp',
        '/images/bench/sequence/hero-key-2.webp',
        '/images/bench/sequence/hero-key-3.webp',
        '/images/bench/sequence/hero-key-4.webp',
      ];

      const layerBack = document.getElementById('layer-back');
      const layerFront = document.getElementById('layer-front');
      const counter = document.getElementById('counter');
      const hint = document.getElementById('scroll-hint');

      if (!layerBack || !layerFront || !counter || !hint) {
        console.error('Flyover: missing DOM elements');
        return;
      }

      const imgBack = layerBack.querySelector('img');
      const imgFront = layerFront.querySelector('img');
      if (!imgBack || !imgFront) return;

      let currentFrame = 0;
      let activeLayer = 'front'; // which layer is currently visible

      // Preload all frames
      frames.forEach(src => { const i = new Image(); i.src = src; });

      const PAN_RANGE = 10; // % of translateY per segment — tuned to match Gemini shift

      ScrollTrigger.create({
        trigger: '#flyover',
        start: 'top top',
        end: 'bottom bottom',
        onUpdate: (self) => {
          const p = self.progress;

          // Which key frame segment?
          const segmentFloat = p * frames.length;
          const segment = Math.min(frames.length - 1, Math.floor(segmentFloat));
          const segmentProgress = Math.min(1, segmentFloat - segment);

          // Get references to active and inactive layers
          const activeEl = activeLayer === 'front' ? layerFront : layerBack;
          const inactiveEl = activeLayer === 'front' ? layerBack : layerFront;
          const activeImg = activeLayer === 'front' ? imgFront : imgBack;
          const inactiveImg = activeLayer === 'front' ? imgBack : imgFront;

          // Key frame swap needed?
          if (segment !== currentFrame) {
            // Load new frame on the INACTIVE (hidden) layer at translateY=0
            inactiveImg.setAttribute('src', frames[segment]);
            inactiveImg.style.transform = 'translateY(0%)';

            // Crossfade: show inactive, hide active
            inactiveEl.classList.remove('is-hidden');
            activeEl.classList.add('is-hidden');

            // Swap active reference
            activeLayer = activeLayer === 'front' ? 'back' : 'front';
            currentFrame = segment;
            counter.textContent = 'F' + (segment + 1) + '/4';
          }

          // Continuous pan on the ACTIVE layer
          const nowActiveImg = activeLayer === 'front' ? imgFront : imgBack;
          const yOffset = -segmentProgress * PAN_RANGE;
          nowActiveImg.style.transform = 'translateY(' + yOffset + '%)';

          // Fade scroll hint
          hint.style.opacity = p > 0.05 ? '0' : '1';
        }
      });

      console.log('Flyover: ready — crossfade + continuous pan');
    });
  </script>
</body>
</html>
