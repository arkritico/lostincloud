---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BenchEngine from '../../components/BenchEngine.astro';
import BenchHero from '../../components/bench/BenchHero.astro';
import BenchAbout from '../../components/bench/BenchAbout.astro';
import BenchServices from '../../components/bench/BenchServices.astro';
import BenchProducts from '../../components/bench/BenchProducts.astro';
import BenchResearch from '../../components/bench/BenchResearch.astro';
import BenchTeam from '../../components/bench/BenchTeam.astro';
import BenchAwards from '../../components/bench/BenchAwards.astro';
import BenchEU from '../../components/bench/BenchEU.astro';
import BenchContact from '../../components/bench/BenchContact.astro';

const locale = 'en';
---

<BaseLayout
  title="lostincloud — Mycology Research Laboratory"
  description="Biotechnology in service of sustainable agriculture. Molecular identification, soil diagnostics, NIR spectroscopy, drones and biological solutions."
  locale={locale}
  canonicalPath="/en/"
>
  <Nav locale={locale} />

  <main id="main">
    <BenchHero locale={locale} />
    <BenchAbout locale={locale} />
    <BenchServices locale={locale} />
    <BenchProducts locale={locale} />
    <BenchResearch locale={locale} />
    <BenchTeam locale={locale} />
    <BenchAwards locale={locale} />
    <BenchEU locale={locale} />
    <BenchContact locale={locale} />
  </main>

  <Footer locale={locale} />
  <BenchEngine />
</BaseLayout>

<style>
  main {
    position: relative;
    overflow-x: hidden;
  }

  @media (max-width: 768px) {
    main {
      scroll-snap-type: y proximity;
    }
  }
</style>
